          "attributes": {
            "content": "apiVersion: traefik.io/v1alpha1\nkind: Middleware\nmetadata:\n  name: weblogic-tls-headers\n  namespace: weblogic-domain1-ns\nspec:\n  headers:\n    customRequestHeaders:\n      WL-Proxy-SSL: \"true\"\n      X-Forwarded-Proto: \"https\"\n\n---\n# HTTPS route für /console\napiVersion: traefik.io/v1alpha1\nkind: IngressRoute\nmetadata:\n  name: sample-domain1-console\n  namespace: weblogic-domain1-ns\nspec:\n  entryPoints:\n    - websecure\n  routes:\n    - match: PathPrefix(`/console`)\n      kind: Rule\n      middlewares:\n        - name: weblogic-tls-headers\n      services:\n        - name: sample-domain1-admin-server\n          port: 7001\n  tls: {}\n\n---\n# HTTP route für /console (für WebLogic-Redirects auf http://IP:31320)\napiVersion: traefik.io/v1alpha1\nkind: IngressRoute\nmetadata:\n  name: sample-domain1-console-http\n  namespace: weblogic-domain1-ns\nspec:\n  entryPoints:\n    - websecure\n  routes:\n    - match: PathPrefix(`/console`)\n      kind: Rule\n      middlewares:\n        - name: weblogic-tls-headers\n      services:\n        - name: sample-domain1-admin-server\n          port: 7001\n\n---\n# HTTPS route für /quickstart\napiVersion: traefik.io/v1alpha1\nkind: IngressRoute\nmetadata:\n  name: sample-domain1-quickstart\n  namespace: weblogic-domain1-ns\nspec:\n  entryPoints:\n    - websecure\n  routes:\n    - match: PathPrefix(`/quickstart`)\n      kind: Rule\n      middlewares:\n        - name: weblogic-tls-headers\n      services:\n        - name: sample-domain1-cluster-cluster-1\n          port: 8001\n  tls: {}\n\n---\n# HTTP route für /quickstart (für WebLogic-Redirects auf http://IP:31320)\napiVersion: traefik.io/v1alpha1\nkind: IngressRoute\nmetadata:\n  name: sample-domain1-quickstart-http\n  namespace: weblogic-domain1-ns\nspec:\n  entryPoints:\n    - websecure\n  routes:\n    - match: PathPrefix(`/quickstart`)\n      kind: Rule\n      middlewares:\n        - name: weblogic-tls-headers\n      services:\n        - name: sample-domain1-cluster-cluster-1\n          port: 8001\n\n---\n# HTTPS route für /rconsole (WebLogic Remote Console)\napiVersion: traefik.io/v1alpha1\nkind: IngressRoute\nmetadata:\n  name: sample-domain1-rconsole\n  namespace: weblogic-domain1-ns\nspec:\n  entryPoints:\n    - websecure\n  routes:\n    - match: PathPrefix(`/rconsole`)\n      kind: Rule\n      middlewares:\n        - name: weblogic-tls-headers\n      services:\n        - name: sample-domain1-admin-server\n          port: 7001\n  tls: {}\n\n---\n# HTTP route für /rconsole (für WebLogic-Redirects)\napiVersion: traefik.io/v1alpha1\nkind: IngressRoute\nmetadata:\n  name: sample-domain1-rconsole-http\n  namespace: weblogic-domain1-ns\nspec:\n  entryPoints:\n    - websecure\n  routes:\n    - match: PathPrefix(`/rconsole`)\n      kind: Rule\n      middlewares:\n        - name: weblogic-tls-headers\n      services:\n        - name: sample-domain1-admin-server\n          port: 7001\n",
